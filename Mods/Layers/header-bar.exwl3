@name "header-bar"
@version "1.0.0"
@description "Adds a header bar and nav placeholder at the top of the page"
@modifies kernel
@dependencies []

html prepend #app {
  <div id="exw3-header-wrap">
    <header id="exw3-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; text-align: center;">
      <h1 id="exw3-site-title" style="margin: 0; font-size: 2em;">EXW3 Local Site</h1>
    </header>
    <nav id="exw3-nav"></nav>
  </div>
}
